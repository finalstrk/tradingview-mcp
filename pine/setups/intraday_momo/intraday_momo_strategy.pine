//@version=6
strategy("DT Intraday Momentum v1", overlay=true, initial_capital=1000000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=10,
     commission_type=strategy.commission.percent, commission_value=0.005,
     slippage=2, process_orders_on_close=true, calc_on_every_tick=false)

// Inputs
groupSession = "Session"
sessionPreset = input.string("RTH", "Session preset", options=["Tokyo", "London", "NY", "RTH", "Custom"], group=groupSession)
customSession = input.session("0930-1600", "Custom session", group=groupSession)
customTimezone = input.string("America/New_York", "Custom timezone", group=groupSession)
openWindow = input.session("0930-1000", "Opening return window override (Custom preset only)", tooltip="Used only when Session preset = Custom. For Tokyo/London/NY/RTH the opening window is auto-derived as [session open, session open + 30min].", group=groupSession)
decisionWindow = input.session("1530-1600", "Decision window override (Custom preset only)", tooltip="Used only when Session preset = Custom. For Tokyo/London/NY/RTH the decision time is auto-derived as session close - 30min. T = the confirmed bar whose close reaches that time.", group=groupSession)

groupRisk = "Risk"
slAtrMult = input.float(1.5, "SL (ATR mult)", minval=0.1, step=0.1, group=groupRisk)
tp1AtrMult = input.float(1.0, "TP1 (ATR mult, 50% off)", minval=0.1, step=0.1, group=groupRisk)

// Session preset resolution (mirrors DT ORB v1 convention)
sessStr = switch sessionPreset
    "Tokyo" => "0900-1500"
    "London" => "0800-1630"
    "NY" => "0930-1600"
    "RTH" => "0930-1600"
    => customSession

tzStr = switch sessionPreset
    "Tokyo" => "Asia/Tokyo"
    "London" => "Europe/London"
    "NY" => "America/New_York"
    "RTH" => "America/New_York"
    => customTimezone

// Fail-closed timeframe guard: see intraday_momo_indicator.pine for rationale
// (1m/5m/15m intraday charts only, explicit allowlist; 60m+, other intraday
// resolutions, and non-time-based charts are unsupported).
timeframeOk = timeframe.isintraday and (timeframe.period == "1" or timeframe.period == "5" or timeframe.period == "15")

// Derive the opening-return window and decision window from the resolved
// session string for preset sessions; Custom preset keeps explicit
// user-supplied windows. See intraday_momo_indicator.pine for full rationale.
f_pad2(_n) =>
    _n < 10 ? "0" + str.tostring(_n) : str.tostring(_n)

f_formatHHMM(_totalMin) =>
    wrapped = ((_totalMin % 1440) + 1440) % 1440
    hh = int(wrapped / 60)
    mm = int(wrapped % 60)
    f_pad2(hh) + f_pad2(mm)

f_hhmmToMin(_hhmm) =>
    int(str.tonumber(str.substring(_hhmm, 0, 2))) * 60 + int(str.tonumber(str.substring(_hhmm, 2, 4)))

f_sessionBounds(_s) =>
    parts = str.split(_s, "-")
    startRaw = array.size(parts) > 0 ? array.get(parts, 0) : ""
    endRaw = array.size(parts) > 1 ? array.get(parts, 1) : ""
    startParts = str.split(startRaw, ":")
    endParts = str.split(endRaw, ":")
    startClean = array.size(startParts) > 0 ? array.get(startParts, 0) : startRaw
    endClean = array.size(endParts) > 0 ? array.get(endParts, 0) : endRaw
    [f_hhmmToMin(startClean), f_hhmmToMin(endClean)]

[sessStartMin, sessEndMin] = f_sessionBounds(sessStr)
derivedOpenWindowEndMin = sessStartMin + 30
derivedDecisionStartMin = sessEndMin - 30

windowsCoherent = derivedOpenWindowEndMin > sessStartMin and derivedOpenWindowEndMin <= sessEndMin and derivedDecisionStartMin >= derivedOpenWindowEndMin and derivedDecisionStartMin < sessEndMin and derivedDecisionStartMin >= sessStartMin

isCustomPreset = sessionPreset == "Custom"
windowsOk = isCustomPreset or windowsCoherent
effectiveOpenWindow = isCustomPreset ? openWindow : f_formatHHMM(sessStartMin) + "-" + f_formatHHMM(derivedOpenWindowEndMin)
effectiveDecisionWindow = isCustomPreset ? decisionWindow : f_formatHHMM(derivedDecisionStartMin) + "-" + f_formatHHMM(sessEndMin)

// configOk gates every stateful/order-producing calculation below, so an
// incoherent derived window fails closed (no entries) instead of trading
// off a bad window.
configOk = timeframeOk and windowsOk

inSession = configOk and not na(time(timeframe.period, sessStr, tzStr))
// Close-based session/window membership: used to detect the LAST bar of the
// session (for the EOD exit) and the LAST bar inside the opening window /
// the bar whose close reaches decision time T, without relying on a
// subsequent out-of-session bar existing.
closeInSession = configOk and not na(time_close(timeframe.period, sessStr, tzStr))
closeInOpenWindow = configOk and not na(time_close(timeframe.period, effectiveOpenWindow, tzStr))
closeInDecisionWindow = configOk and not na(time_close(timeframe.period, effectiveDecisionWindow, tzStr))
isNewDay = timeframe.change("D")

// Single managed warning label, mirroring the indicator (not recreated every
// barstate.islast tick), so a misconfigured preset/timeframe is visible
// directly on the strategy chart, not just inferred from zero trades.
var label configWarnLabel = na
warnText = not timeframeOk ? "DT Intraday Momentum v1: unsupported timeframe (1m/5m/15m only)" : not windowsOk ? "DT Intraday Momentum v1: derived session windows incoherent for preset '" + sessionPreset + "' - session too short" : na
if barstate.islast
    if not na(warnText)
        if na(configWarnLabel)
            configWarnLabel := label.new(bar_index, high, warnText, style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white)
        else
            label.set_xy(configWarnLabel, bar_index, high)
            label.set_text(configWarnLabel, warnText)
    else if not na(configWarnLabel)
        label.delete(configWarnLabel)
        configWarnLabel := na

// Safety flatten: if a position somehow survived into a new session (e.g. a
// data gap suppressed the prior day's EOD close bar), do not let it sit
// unmanaged or seed the new day's tradedToday state incorrectly.
if isNewDay and strategy.position_size != 0
    strategy.close_all("Carryover flatten")

// Session-open anchor and first-N-minute (opening window) return
sessionOpenTrigger = inSession and not inSession[1]
openWindowExitTrigger = closeInOpenWindow[1] and not closeInOpenWindow
decisionTrigger = closeInDecisionWindow and not closeInDecisionWindow[1]
// Final session bar: this bar's open is still inside the session but its
// close is not (session end reached/passed within this bar) -- fires the
// EOD exit on the last real session bar itself instead of requiring a
// subsequent out-of-session bar, which never exists on an RTH-only feed.
isFinalSessionBar = inSession and not closeInSession

var float sessionOpenPrice = na
var float open30Return = na
var bool open30Locked = false
var bool tradedToday = false
var float activeStop = na
var float activeTp1 = na

if isNewDay
    sessionOpenPrice := na
    open30Return := na
    open30Locked := false
    tradedToday := false

if sessionOpenTrigger
    sessionOpenPrice := open

// Lock the first-N-minute return off the confirmed close of the LAST bar
// inside the opening window (close[1] on the first bar after exit).
if openWindowExitTrigger and not na(sessionOpenPrice) and barstate.isconfirmed
    open30Return := close[1] / sessionOpenPrice - 1.0
    open30Locked := true

atrValue = ta.atr(14)
daySoFarReturn = na(sessionOpenPrice) ? na : close / sessionOpenPrice - 1.0
sameSign = open30Locked and not na(open30Return) and not na(daySoFarReturn) and open30Return != 0.0 and daySoFarReturn != 0.0 and math.sign(open30Return) == math.sign(daySoFarReturn)

// Decision bar T = the bar whose confirmed close reaches decisionWindow's
// start time. Gated on barstate.isconfirmed so an order cannot be sized off
// a still-forming intrabar close that later settles to a different price.
longSignal = decisionTrigger and inSession and barstate.isconfirmed and sameSign and open30Return > 0.0 and not tradedToday
shortSignal = decisionTrigger and inSession and barstate.isconfirmed and sameSign and open30Return < 0.0 and not tradedToday

// Entries and exits. SL/TP1 are placed in the same signal block as the
// entry (using the local sl/tp values, not a var that could lag behind by a
// bar) so the entry bar itself is protected immediately, not left naked
// until the next bar's re-issue block runs.
if longSignal
    sl = close - atrValue * slAtrMult
    tp1 = close + atrValue * tp1AtrMult
    activeStop := sl
    activeTp1 := tp1
    strategy.entry("Long", strategy.long)
    strategy.exit("L-TP1", "Long", qty_percent=50, stop=sl, limit=tp1)
    strategy.exit("L-SL", "Long", qty_percent=50, stop=sl)
    tradedToday := true

if shortSignal
    sl = close + atrValue * slAtrMult
    tp1 = close - atrValue * tp1AtrMult
    activeStop := sl
    activeTp1 := tp1
    strategy.entry("Short", strategy.short)
    strategy.exit("S-TP1", "Short", qty_percent=50, stop=sl, limit=tp1)
    strategy.exit("S-SL", "Short", qty_percent=50, stop=sl)
    tradedToday := true

// TP1 takes 50% off at 1x ATR (DT-contract overlay, not source-validated); the
// remainder rides the disaster stop to the hard EOD time exit below (TP2 =
// session close, matching the source study's "let it run to close" behavior).
// Re-issuing every bar the position is open is redundant on the entry bar
// itself (already placed above) but keeps the orders resubmitted/visible on
// subsequent bars using the same stop/limit levels.
if strategy.position_size > 0 and not na(activeStop) and not na(activeTp1)
    strategy.exit("L-TP1", "Long", qty_percent=50, stop=activeStop, limit=activeTp1)
    strategy.exit("L-SL", "Long", qty_percent=50, stop=activeStop)

if strategy.position_size < 0 and not na(activeStop) and not na(activeTp1)
    strategy.exit("S-TP1", "Short", qty_percent=50, stop=activeStop, limit=activeTp1)
    strategy.exit("S-SL", "Short", qty_percent=50, stop=activeStop)

// Hard EOD flat: exit on the final confirmed session bar itself (this bar's
// open is in-session, its close is not), regardless of TP1/SL status
// (TP2 = time exit). Detecting the boundary via time_close means this fires
// even on an RTH-only feed with no bars after the session close, instead of
// requiring a subsequent out-of-session bar that may never arrive.
if isFinalSessionBar and barstate.isconfirmed
    strategy.close_all("EOD")
    activeStop := na
    activeTp1 := na

// Visual markers
plotshape(longSignal, title="Momo Long Entry", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), text="Momo L", size=size.tiny)
plotshape(shortSignal, title="Momo Short Entry", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), text="Momo S", size=size.tiny)
plot(na(sessionOpenPrice) ? na : sessionOpenPrice, title="Session Open", color=color.new(color.blue, 60), style=plot.style_circles)
