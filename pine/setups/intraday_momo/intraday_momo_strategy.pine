//@version=6
strategy("DT Intraday Momentum v1", overlay=true, initial_capital=1000000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=10,
     commission_type=strategy.commission.percent, commission_value=0.005,
     slippage=2, process_orders_on_close=true, calc_on_every_tick=false)

// Inputs
groupSession = "Session"
sessionPreset = input.string("RTH", "Session preset", options=["Tokyo", "London", "NY", "RTH", "Custom"], group=groupSession)
customSession = input.session("0930-1600", "Custom session", group=groupSession)
customTimezone = input.string("America/New_York", "Custom timezone", group=groupSession)
openWindow = input.session("0930-1000", "Opening return window override (Custom preset only)", tooltip="Used only when Session preset = Custom. For Tokyo/London/NY/RTH the opening window is auto-derived as [session open, session open + 30min]. Only the window END time is consumed: the first-30-minute return locks on the confirmed close of the bar whose close time reaches it.", group=groupSession)
decisionWindow = input.session("1530-1600", "Decision window override (Custom preset only)", tooltip="Used only when Session preset = Custom. For Tokyo/London/NY/RTH the decision time is auto-derived as session close - 30min. Only the window START time is consumed: the decision fires on the confirmed close of the bar whose close time reaches it.", group=groupSession)

groupRisk = "Risk"
slAtrMult = input.float(1.5, "SL (ATR mult)", minval=0.1, step=0.1, group=groupRisk)
tp1AtrMult = input.float(1.0, "TP1 (ATR mult, 50% off)", minval=0.1, step=0.1, group=groupRisk)

// Session preset resolution (mirrors DT ORB v1 convention)
sessStr = switch sessionPreset
    "Tokyo" => "0900-1500"
    "London" => "0800-1630"
    "NY" => "0930-1600"
    "RTH" => "0930-1600"
    => customSession

tzStr = switch sessionPreset
    "Tokyo" => "Asia/Tokyo"
    "London" => "Europe/London"
    "NY" => "America/New_York"
    "RTH" => "America/New_York"
    => customTimezone

// Fail-closed timeframe guard: see intraday_momo_indicator.pine for rationale
// (1m/5m/15m intraday charts only, explicit allowlist; other intraday
// resolutions, 60m+, and non-time-based charts are unsupported).
timeframeOk = timeframe.isintraday and (timeframe.period == "1" or timeframe.period == "5" or timeframe.period == "15")

// Derive the opening-window end and decision time from the resolved session
// string for preset sessions (open+30min / close-30min); Custom preset keeps
// explicit user-supplied windows. See intraday_momo_indicator.pine for the
// full rationale and the Tokyo-preset silent-failure example this fixes.
f_hhmmToMin(_hhmm) =>
    int(str.tonumber(str.substring(_hhmm, 0, 2))) * 60 + int(str.tonumber(str.substring(_hhmm, 2, 4)))

f_sessionBounds(_s) =>
    parts = str.split(_s, "-")
    startRaw = array.size(parts) > 0 ? array.get(parts, 0) : ""
    endRaw = array.size(parts) > 1 ? array.get(parts, 1) : ""
    startParts = str.split(startRaw, ":")
    endParts = str.split(endRaw, ":")
    startClean = array.size(startParts) > 0 ? array.get(startParts, 0) : startRaw
    endClean = array.size(endParts) > 0 ? array.get(endParts, 0) : endRaw
    [f_hhmmToMin(startClean), f_hhmmToMin(endClean)]

[sessStartMin, sessEndMin] = f_sessionBounds(sessStr)
[owStartMin, owEndMin] = f_sessionBounds(openWindow)
[dwStartMin, dwEndMin] = f_sessionBounds(decisionWindow)

isCustomPreset = sessionPreset == "Custom"
openWindowEndMin = isCustomPreset ? owEndMin : sessStartMin + 30
decisionTimeMin = isCustomPreset ? dwStartMin : sessEndMin - 30

// Coherence check (presets AND Custom); fails closed with a warning label.
// Overnight sessions (start > end) are rejected — minute-of-day comparison
// does not support midnight wraps (accepted library-wide limitation).
windowsOk = sessStartMin < sessEndMin and openWindowEndMin > sessStartMin and openWindowEndMin < sessEndMin and decisionTimeMin >= openWindowEndMin and decisionTimeMin < sessEndMin

// configOk gates every stateful/order-producing calculation below, so an
// incoherent configuration fails closed (no entries) instead of trading off
// a bad window.
configOk = timeframeOk and windowsOk

inSession = configOk and not na(time(timeframe.period, sessStr, tzStr))
isNewDay = timeframe.change("D")

// Minute-of-day of this bar's close, in the session timezone (same mechanism
// as the DT Noise Area Breakout v1 checkpoint detection).
barCloseMin = hour(time_close, tzStr) * 60 + minute(time_close, tzStr)

// Single managed warning label, mirroring the indicator, so a misconfigured
// preset/timeframe is visible directly on the strategy chart instead of only
// inferred from zero trades.
var label configWarnLabel = na
warnText = not timeframeOk ? "DT Intraday Momentum v1: unsupported timeframe (1m/5m/15m only)" : not windowsOk ? "DT Intraday Momentum v1: incoherent session windows for preset '" + sessionPreset + "' (need open+30min and close-30min inside the session, no midnight wrap)" : na
if barstate.islast
    if not na(warnText)
        if na(configWarnLabel)
            configWarnLabel := label.new(bar_index, high, warnText, style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white)
        else
            label.set_xy(configWarnLabel, bar_index, high)
            label.set_text(configWarnLabel, warnText)
    else if not na(configWarnLabel)
        label.delete(configWarnLabel)
        configWarnLabel := na

// Safety flatten: if a position somehow survived into a new session (e.g. a
// data gap suppressed the prior day's final session bar), do not let it sit
// unmanaged or seed the new day's tradedToday state incorrectly.
if isNewDay and strategy.position_size != 0
    strategy.close_all("Carryover flatten")

// First in-session bar after either a session gap (inSession[1] false) or a
// new-day reset (isNewDay true). See intraday_momo_indicator.pine for the
// RTH-only-feed rationale this fixes: the plain transition only fires once,
// on day 1, when the feed has no after-hours bars to flip inSession false.
sessionOpenTrigger = inSession and (not inSession[1] or isNewDay)

var float sessionOpenPrice = na
var float open30Return = na
var bool open30Locked = false
var bool decisionResolved = false
var bool tradedToday = false
var float activeStop = na
var float activeTp1 = na

if isNewDay
    sessionOpenPrice := na
    open30Return := na
    open30Locked := false
    decisionResolved := false
    tradedToday := false

if sessionOpenTrigger
    sessionOpenPrice := open

// Lock the first-N-minute return on the confirmed close of the LAST bar
// inside the opening window: the first confirmed in-session bar whose close
// time reaches the opening-window end (e.g. the 09:55-10:00 bar on a 5m
// chart, closing exactly at 10:00). Gated on barstate.isconfirmed so the
// lock cannot fire off a still-forming realtime bar.
openWindowLockEvent = inSession and not open30Locked and not na(sessionOpenPrice) and barstate.isconfirmed and barCloseMin >= openWindowEndMin
if openWindowLockEvent
    open30Return := close / sessionOpenPrice - 1.0
    open30Locked := true

atrValue = ta.atr(14)
daySoFarReturn = na(sessionOpenPrice) ? na : close / sessionOpenPrice - 1.0
sameSign = open30Locked and not na(open30Return) and not na(daySoFarReturn) and open30Return != 0.0 and daySoFarReturn != 0.0 and math.sign(open30Return) == math.sign(daySoFarReturn)

// Decision bar T = the first confirmed in-session bar whose close time
// reaches the decision time (session close - 30min for presets), i.e. the
// bar CLOSING at T, not the bar starting at T (which would decide one bar
// late: 15:35/15:45 on 5m/15m). barstate.isconfirmed prevents sizing an
// order off a still-forming intrabar close that later settles differently.
decisionEvent = inSession and not decisionResolved and barstate.isconfirmed and barCloseMin >= decisionTimeMin
longSignal = decisionEvent and sameSign and open30Return > 0.0 and not tradedToday
shortSignal = decisionEvent and sameSign and open30Return < 0.0 and not tradedToday
if decisionEvent
    decisionResolved := true

// Entries and exits. SL/TP1 are placed in the same signal block as the entry
// (with the freshly computed prices, not a var that could lag a bar) so the
// entry bar itself is protected immediately, not left naked until the next
// bar's re-issue block runs.
if longSignal
    sl = close - atrValue * slAtrMult
    tp1 = close + atrValue * tp1AtrMult
    activeStop := sl
    activeTp1 := tp1
    strategy.entry("Long", strategy.long)
    strategy.exit("L-TP1", "Long", qty_percent=50, stop=sl, limit=tp1)
    strategy.exit("L-SL", "Long", qty_percent=50, stop=sl)
    tradedToday := true

if shortSignal
    sl = close + atrValue * slAtrMult
    tp1 = close - atrValue * tp1AtrMult
    activeStop := sl
    activeTp1 := tp1
    strategy.entry("Short", strategy.short)
    strategy.exit("S-TP1", "Short", qty_percent=50, stop=sl, limit=tp1)
    strategy.exit("S-SL", "Short", qty_percent=50, stop=sl)
    tradedToday := true

// TP1 takes 50% off at 1x ATR (DT-contract overlay, not source-validated);
// the remainder rides the disaster stop to the hard EOD time exit below
// (TP2 = session close, matching the source study's "let it run to close"
// behavior). Re-issuing while the position is open keeps the exit orders
// active on bars after the entry bar (same stop/limit levels).
if strategy.position_size > 0 and not na(activeStop) and not na(activeTp1)
    strategy.exit("L-TP1", "Long", qty_percent=50, stop=activeStop, limit=activeTp1)
    strategy.exit("L-SL", "Long", qty_percent=50, stop=activeStop)

if strategy.position_size < 0 and not na(activeStop) and not na(activeTp1)
    strategy.exit("S-TP1", "Short", qty_percent=50, stop=activeStop, limit=activeTp1)
    strategy.exit("S-SL", "Short", qty_percent=50, stop=activeStop)

// Hard EOD flat: exit on the final session bar itself — the first confirmed
// in-session bar whose close time reaches the session end (e.g. the
// 15:55-16:00 bar on a 5m RTH chart). With process_orders_on_close=true the
// flatten fills at that bar's close, i.e. the session-close price. Detecting
// the boundary via the bar's own close time means this fires even on an
// RTH-only feed with no bars after the session close — the old
// `inSession[1] and not inSession` transition required a subsequent
// out-of-session bar that never exists there, silently carrying positions
// overnight. The isNewDay carryover flatten above remains as a backstop for
// days whose final session bar is missing from the feed entirely.
isFinalSessionBar = inSession and barstate.isconfirmed and barCloseMin >= sessEndMin
if isFinalSessionBar and strategy.position_size != 0
    strategy.close_all("EOD")
    activeStop := na
    activeTp1 := na

// Visual markers
plotshape(longSignal, title="Momo Long Entry", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), text="Momo L", size=size.tiny)
plotshape(shortSignal, title="Momo Short Entry", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), text="Momo S", size=size.tiny)
plot(na(sessionOpenPrice) ? na : sessionOpenPrice, title="Session Open", color=color.new(color.blue, 60), style=plot.style_circles)
