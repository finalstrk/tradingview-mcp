//@version=6
strategy("DT Noise Area Breakout v1", overlay=true, initial_capital=1000000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=10,
     commission_type=strategy.commission.percent, commission_value=0.005,
     slippage=2, process_orders_on_close=true, calc_on_every_tick=false)

// Input groups
string groupSession = "Session"
string groupSetup = "Setup"
string groupRisk = "Risk"

// Session inputs
sessionPreset = input.string("RTH", "Session preset", options=["Tokyo", "London", "NY", "RTH", "Custom"], group=groupSession)
customSession = input.session("0930-1600", "Custom session", group=groupSession)
customTimezone = input.string("America/New_York", "Custom timezone", group=groupSession)
warmupWindow = input.session("0930-1000", "Warmup window (no entries, first 30 min)", group=groupSession)

// Setup inputs — see noise_break_indicator.pine header comment for the
// avgAbsMove fallback design rationale (per-time-of-day matrix rejected as
// too fragile for Pine v6; a per-day scalar rolling average used instead).
lookbackDays = input.int(14, "Avg move lookback (days)", minval=3, group=groupSetup)
minWarmupDays = input.int(5, "Min completed days before signals are valid", minval=1, group=groupSetup)
noiseMult = input.float(1.0, "Noise band multiplier", minval=0.1, step=0.1, group=groupSetup)

// Risk inputs — TP1/TP2 are a DT overlay on top of the source logic (untested).
tp1Mult = input.float(1.0, "TP1 distance (x band width)", minval=0.1, step=0.1, group=groupRisk)
tp2Mult = input.float(2.0, "TP2 distance (x band width)", minval=0.1, step=0.1, group=groupRisk)

// Checkpoint gating — the source logic (family_orderflow.md Candidate 2,
// citing the Zarattini et al. SSRN working paper) evaluates breakouts only
// at fixed half-hour decision checkpoints (HH:00 / HH:30 session time), not
// continuously on every bar close. Default true reproduces that behavior;
// set to false for an explicitly unvalidated continuous-evaluation variant
// (no source study backs continuous evaluation — see README).
checkpointOnly = input.bool(true, "Checkpoint-only entries (HH:00/HH:30, per source)", tooltip="Source (family_orderflow.md Candidate 2 / Zarattini et al. SSRN working paper) evaluates breakouts only at fixed half-hour decision checkpoints (HH:00 and HH:30 in the session timezone). When true, long/short signals can only fire on a confirmed bar whose close lands on one of those checkpoints. When false, signals evaluate continuously on every confirmed bar close — an explicitly unvalidated variant with no source backing.", group=groupSetup)

// Session resolution
sessStr = switch sessionPreset
    "Tokyo" => "0900-1500"
    "London" => "0800-1630"
    "NY" => "0930-1600"
    "RTH" => "0930-1600"
    => customSession

tzStr = switch sessionPreset
    "Tokyo" => "Asia/Tokyo"
    "London" => "Europe/London"
    "NY" => "America/New_York"
    "RTH" => "America/New_York"
    => customTimezone

inSession = not na(time(timeframe.period, sessStr, tzStr))
inWarmup = not na(time(timeframe.period, warmupWindow, tzStr))
isNewDay = timeframe.change("D")
sessionStart = inSession and not inSession[1]

// Persistent state
var array<float> moveHistory = array.new<float>(0)
var float sessionOpenToday = na
var float lastSessionClose = na
var bool tradedLongToday = false
var bool tradedShortToday = false
var float activeStop = na
var float activeTp1 = na
var float activeTp2 = na
var float sumPV = na
var float sumVol = na

// Session VWAP — anchored to session start (not the exchange daily
// boundary) and accumulated only over in-session bars, so pre/post-session
// bars on a chart that includes them cannot skew the session VWAP (finding:
// ta.vwap(..., isNewDay, ...) reset on the exchange day boundary and kept
// accumulating on every bar regardless of session membership). Manual
// running sum because ta.vwap has no "skip this bar" input.
if sessionStart
    sumPV := 0.0
    sumVol := 0.0
if inSession
    sumPV := nz(sumPV) + hlc3 * volume
    sumVol := nz(sumVol) + volume
vwapVal = sumVol > 0 ? sumPV / sumVol : na

// Session end time (hour, minute), parsed from sessStr, used below to
// detect the final in-session bar for the EOD flat without depending on a
// subsequent out-of-session bar existing on the chart (finding: on an
// RTH-only data feed, `inSession[1] and not inSession` never fires because
// no out-of-session bar ever arrives, so the EOD close silently never runs).
// Same split-on-"-"/split-on-":" idiom as pine/setups/torb/torb_strategy.pine
// f_sessionMinutes, so a day-of-week suffix on input.session (e.g.
// "0930-1600:23456") is stripped the same way the rest of this library does.
f_sessionEndParts(_s) =>
    parts = str.split(_s, "-")
    endRaw = array.size(parts) > 1 ? array.get(parts, 1) : ""
    endParts = str.split(endRaw, ":")
    endClean = array.size(endParts) > 0 ? array.get(endParts, 0) : endRaw
    endHour = int(str.tonumber(str.substring(endClean, 0, 2)))
    endMinute = int(str.tonumber(str.substring(endClean, 2, 4)))
    [endHour, endMinute]

[sessionEndHour, sessionEndMinute] = f_sessionEndParts(sessStr)
closeHourTz = hour(time_close, tzStr)
closeMinuteTz = minute(time_close, tzStr)
isLastSessionBar = inSession and (closeHourTz > sessionEndHour or (closeHourTz == sessionEndHour and closeMinuteTz >= sessionEndMinute))

if isNewDay
    if not na(sessionOpenToday) and not na(lastSessionClose) and sessionOpenToday > 0
        dayMove = math.abs(lastSessionClose / sessionOpenToday - 1)
        array.push(moveHistory, dayMove)
        if array.size(moveHistory) > lookbackDays
            array.shift(moveHistory)
    sessionOpenToday := na
    lastSessionClose := na
    tradedLongToday := false
    tradedShortToday := false

if inSession
    if na(sessionOpenToday)
        sessionOpenToday := open
    lastSessionClose := close

// Clamp: minWarmupDays cannot exceed lookbackDays, because moveHistory is
// itself capped at lookbackDays entries (array.shift above). Without this
// clamp, minWarmupDays > lookbackDays makes hasHistory permanently false
// and the setup silently never signals — see README.
effectiveWarmupDays = math.min(minWarmupDays, lookbackDays)
hasHistory = array.size(moveHistory) >= effectiveWarmupDays
avgAbsMove = hasHistory ? array.avg(moveHistory) : na
// hasBoundaryData intentionally does NOT require inSession — sessionOpenToday
// and avgAbsMove both persist after the session closes (reset only on the
// next isNewDay). Actual order entry is still gated on inSession via canEnter.
hasBoundaryData = not na(sessionOpenToday) and sessionOpenToday > 0 and not na(avgAbsMove)
upperBoundary = hasBoundaryData ? sessionOpenToday * (1 + noiseMult * avgAbsMove) : na
lowerBoundary = hasBoundaryData ? sessionOpenToday * (1 - noiseMult * avgAbsMove) : na
bandWidth = hasBoundaryData ? upperBoundary - sessionOpenToday : na

// Breakout detection — confirmed-bar close crossing the boundary, no
// request.security, no lookahead. process_orders_on_close=true means the
// strategy.entry below fills at this same confirmed close, matching the DT
// ORB v1 reference convention. barstate.isconfirmed is required explicitly
// (Codex design-review recommendation) even though calc_on_every_tick=false
// already limits recalculation to bar close for this script.
// Checkpoint detection: the confirmed bar's close time, in the session
// timezone, must land exactly on a half-hour boundary (minute 0 or 30).
// This holds for 1m and 5m charts whose bars are aligned to the session
// open on standard round-number boundaries (e.g. a 5m bar spanning
// 09:25:00-09:30:00 closes at 09:30:00 exactly). It is NOT verified for
// charts with non-standard bar alignment or timeframes that do not evenly
// divide 30 minutes (e.g. some custom/renko-style feeds) — checkpointOnly
// should be disabled for those, since minute(time_close, tzStr) % 30 == 0
// may never be true or may fire at the wrong bar.
isCheckpointBar = minute(time_close, tzStr) % 30 == 0
// Checkpoint-mode condition: the source evaluates "is price beyond the
// boundary?" AT each half-hour checkpoint, not "did price cross the
// boundary ON this exact bar?" ta.crossover/crossunder only fire on the
// bar the cross happens, so with checkpointOnly=true a break that occurred
// between checkpoints (and simply remained outside the band) was never
// traded — deviation from source, fixed here. checkpointOnly=true uses a
// level test (close beyond boundary) sampled only on checkpoint bars;
// checkpointOnly=false keeps the crossover semantics as the explicitly
// unvalidated continuous-evaluation variant (no source backing).
longCondition = checkpointOnly ? (isCheckpointBar and close > upperBoundary) : ta.crossover(close, upperBoundary)
shortCondition = checkpointOnly ? (isCheckpointBar and close < lowerBoundary) : ta.crossunder(close, lowerBoundary)
canEnter = inSession and not inWarmup and hasBoundaryData and barstate.isconfirmed
longSignal = canEnter and not tradedLongToday and longCondition
shortSignal = canEnter and not tradedShortToday and shortCondition

// Trailing exit level — source rule is "exit when price crosses back
// through max(upper_boundary, VWAP)" for longs / "min(lower_boundary,
// VWAP)" for shorts (family_orderflow.md Candidate 2), not a bare VWAP
// cross. upperBoundary/lowerBoundary are constant for the session once
// hasBoundaryData is true, so this combines the static band level with the
// live VWAP every bar.
longExitLevel = hasBoundaryData ? math.max(upperBoundary, vwapVal) : vwapVal
shortExitLevel = hasBoundaryData ? math.min(lowerBoundary, vwapVal) : vwapVal

// Entries — strategy.exit/stop orders are placed in the same block as
// strategy.entry, using the known entry-bar prices (activeStop/activeTp1/
// activeTp2 computed just above), instead of relying solely on the later
// `strategy.position_size > 0/<0` blocks below. Pine only updates
// strategy.position_size for the *next* script execution, not within the
// same bar the entry order was placed, so gating the exit orders purely on
// strategy.position_size left the entry bar with no protective stop/TP
// registered until the following bar — a real unprotected-bar gap. Placing
// the exits here closes that gap; the blocks below still re-register the
// updated (trailed) stop/TP on every subsequent bar while the position is
// open.
if longSignal
    tradedLongToday := true
    activeStop := longExitLevel
    activeTp1 := close + bandWidth * tp1Mult
    activeTp2 := close + bandWidth * tp2Mult
    strategy.entry("Long", strategy.long)
    strategy.exit("L-TP1", "Long", qty_percent=50, stop=activeStop, limit=activeTp1)
    strategy.exit("L-TP2", "Long", qty_percent=50, stop=activeStop, limit=activeTp2)

if shortSignal
    tradedShortToday := true
    activeStop := shortExitLevel
    activeTp1 := close - bandWidth * tp1Mult
    activeTp2 := close - bandWidth * tp2Mult
    strategy.entry("Short", strategy.short)
    strategy.exit("S-TP1", "Short", qty_percent=50, stop=activeStop, limit=activeTp1)
    strategy.exit("S-TP2", "Short", qty_percent=50, stop=activeStop, limit=activeTp2)

// Trail the stop to max(upperBoundary, VWAP) / min(lowerBoundary, VWAP)
// every bar while a position is open. This mechanically implements the
// source rule "exit when price crosses back through max/min(boundary,
// VWAP)" — the stop level *is* that band-combined exit. Ratcheted (Codex
// design-review recommendation): the stop only ever tightens toward price,
// so a "trailing" stop cannot loosen if the band-combined level itself
// drifts back against the position intrabar. If the entry-bar level is
// already on the wrong side of entry, the stop is immediately marketable
// and the position exits on the next tick — a real, documented possible
// outcome of the source rule, not a bug.
if strategy.position_size > 0 and not na(vwapVal)
    activeStop := math.max(nz(activeStop, longExitLevel), longExitLevel)

if strategy.position_size < 0 and not na(vwapVal)
    activeStop := math.min(nz(activeStop, shortExitLevel), shortExitLevel)

if strategy.position_size > 0 and not na(activeStop) and not na(activeTp1) and not na(activeTp2)
    strategy.exit("L-TP1", "Long", qty_percent=50, stop=activeStop, limit=activeTp1)
    strategy.exit("L-TP2", "Long", qty_percent=50, stop=activeStop, limit=activeTp2)

if strategy.position_size < 0 and not na(activeStop) and not na(activeTp1) and not na(activeTp2)
    strategy.exit("S-TP1", "Short", qty_percent=50, stop=activeStop, limit=activeTp1)
    strategy.exit("S-TP2", "Short", qty_percent=50, stop=activeStop, limit=activeTp2)

// EOD hard flat — backstop for whatever remains open (matches source's
// "TP2 = remainder EOD flat or VWAP-cross exit, whichever first": the
// trailing VWAP stop above handles the VWAP-cross path, this handles EOD).
// Uses isLastSessionBar (time_close vs. parsed session end, computed above)
// instead of `inSession[1] and not inSession`: the latter requires a bar
// after session close to exist on the chart, which never happens on an
// RTH-only data feed, so the EOD close would silently never fire there.
if isLastSessionBar
    strategy.close_all("EOD")
    activeStop := na
    activeTp1 := na
    activeTp2 := na

// Visual history and levels
upperPlot = plot(hasBoundaryData ? upperBoundary : na, "Upper band", color=color.new(color.green, 0), linewidth=2, style=plot.style_linebr)
lowerPlot = plot(hasBoundaryData ? lowerBoundary : na, "Lower band", color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)
fill(upperPlot, lowerPlot, color=color.new(color.yellow, 92), title="Noise area")
plot(inSession ? vwapVal : na, "Session VWAP", color=color.new(color.blue, 0), linewidth=1)
plotshape(longSignal, title="Noise Break Long", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), text="NB L", size=size.tiny)
plotshape(shortSignal, title="Noise Break Short", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), text="NB S", size=size.tiny)
