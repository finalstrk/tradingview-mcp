//@version=6
strategy("DT PDH PDL Break v1", overlay=true, initial_capital=1000000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=10,
     commission_type=strategy.commission.percent, commission_value=0.005,
     slippage=2, process_orders_on_close=true, calc_on_every_tick=false)

// Inputs
groupSession = "Session"
sessionPreset = input.string("NY", "Session preset", options=["Tokyo", "London", "NY", "RTH", "Custom"], group=groupSession)
customSession = input.session("0930-1600", "Custom session", group=groupSession)
customTimezone = input.string("America/New_York", "Custom timezone", group=groupSession)

groupSignal = "Signal"
retestTimeout = input.int(12, "Retest timeout (bars)", minval=1, group=groupSignal)

// Session preset resolution
sessStr = switch sessionPreset
    "Tokyo" => "0900-1500"
    "London" => "0800-1630"
    "NY" => "0930-1600"
    "RTH" => "0930-1600"
    => customSession

tzStr = switch sessionPreset
    "Tokyo" => "Asia/Tokyo"
    "London" => "Europe/London"
    "NY" => "America/New_York"
    "RTH" => "America/New_York"
    => customTimezone

inSession = not na(time(timeframe.period, sessStr, tzStr))
sessionEnded = inSession[1] and not inSession

// Previous-day levels
// The [1] offset requests the completed daily candle, while lookahead_on only propagates that already-offset value to intraday bars.
// This combination avoids using the current unfinished daily high/low, so PDH/PDL do not repaint intraday.
[pdh, pdl] = request.security(syminfo.tickerid, "D", [high[1], low[1]], lookahead=barmerge.lookahead_on)

// Global per-bar calculations
atr = ta.atr(14)
newDay = timeframe.change("D")
dayRange = pdh - pdl
levelsReady = not na(pdh) and not na(pdl)

// Current levels
plot(pdh, "PDH", color=color.new(color.green, 0), linewidth=1, style=plot.style_linebr)
plot(pdl, "PDL", color=color.new(color.red, 0), linewidth=1, style=plot.style_linebr)

// State machine storage
var int stateL = 0
var int stateS = 0
var int waitBarsL = 0
var int waitBarsS = 0
var bool tradedLongToday = false
var bool tradedShortToday = false

var float longEntry = na
var float longSl = na
var float longTp1 = na
var float longTp2 = na
var float shortEntry = na
var float shortSl = na
var float shortTp1 = na
var float shortTp2 = na

if newDay
    stateL := 0
    stateS := 0
    waitBarsL := 0
    waitBarsS := 0
    tradedLongToday := false
    tradedShortToday := false

if sessionEnded
    strategy.close_all("EOD")
    stateL := 0
    stateS := 0
    waitBarsL := 0
    waitBarsS := 0

// Per-bar event flags
longForming = false
shortForming = false
longSignal = false
shortSignal = false
longExpired = false
shortExpired = false

// Long break and retest
if inSession and levelsReady
    if stateL == 0 and not tradedLongToday and close > pdh
        stateL := 1
        waitBarsL := 0
        longEntry := close
        longSl := low - atr * 0.25
        longTp1 := longEntry + (longEntry - longSl) * 1.5
        longTp2 := pdh + dayRange * 0.5
        longForming := true
    else if stateL == 1
        waitBarsL := waitBarsL + 1
        retestL = low <= pdh and close > pdh
        timeoutL = waitBarsL > retestTimeout
        invalidL = close < pdh
        if retestL and waitBarsL <= retestTimeout and not tradedLongToday
            longEntry := close
            longSl := low - atr * 0.25
            longTp1 := longEntry + (longEntry - longSl) * 1.5
            longTp2 := pdh + dayRange * 0.5
            longSignal := true
            tradedLongToday := true
            stateL := 2
        else if timeoutL
            longExpired := true
            stateL := 0
            waitBarsL := 0
        else if invalidL
            stateL := 0
            waitBarsL := 0

// Short break and retest
if inSession and levelsReady
    if stateS == 0 and not tradedShortToday and close < pdl
        stateS := 1
        waitBarsS := 0
        shortEntry := close
        shortSl := high + atr * 0.25
        shortTp1 := shortEntry - (shortSl - shortEntry) * 1.5
        shortTp2 := pdl - dayRange * 0.5
        shortForming := true
    else if stateS == 1
        waitBarsS := waitBarsS + 1
        retestS = high >= pdl and close < pdl
        timeoutS = waitBarsS > retestTimeout
        invalidS = close > pdl
        if retestS and waitBarsS <= retestTimeout and not tradedShortToday
            shortEntry := close
            shortSl := high + atr * 0.25
            shortTp1 := shortEntry - (shortSl - shortEntry) * 1.5
            shortTp2 := pdl - dayRange * 0.5
            shortSignal := true
            tradedShortToday := true
            stateS := 2
        else if timeoutS
            shortExpired := true
            stateS := 0
            waitBarsS := 0
        else if invalidS
            stateS := 0
            waitBarsS := 0

// Orders are only opened inside the selected session.
if inSession and longSignal and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    strategy.exit("Long TP1/SL", from_entry="Long", qty_percent=50, stop=longSl, limit=longTp1)
    strategy.exit("Long TP2/SL", from_entry="Long", qty_percent=50, stop=longSl, limit=longTp2)

if inSession and shortSignal and strategy.position_size == 0
    strategy.entry("Short", strategy.short)
    strategy.exit("Short TP1/SL", from_entry="Short", qty_percent=50, stop=shortSl, limit=shortTp1)
    strategy.exit("Short TP2/SL", from_entry="Short", qty_percent=50, stop=shortSl, limit=shortTp2)

// Historical markers
plotshape(longForming, title="PDH Break Long Forming", text="Break", style=shape.triangleup, location=location.abovebar, color=color.new(color.green, 0), textcolor=color.white, size=size.tiny)
plotshape(longSignal, title="PDH Retest Long Triggered", text="Retest", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), textcolor=color.white, size=size.tiny)
plotshape(longExpired, title="PDH Retest Long Expired", text="Expired", style=shape.xcross, location=location.abovebar, color=color.new(color.gray, 0), textcolor=color.gray, size=size.tiny)

plotshape(shortForming, title="PDL Break Short Forming", text="Break", style=shape.triangledown, location=location.belowbar, color=color.new(color.red, 0), textcolor=color.white, size=size.tiny)
plotshape(shortSignal, title="PDL Retest Short Triggered", text="Retest", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white, size=size.tiny)
plotshape(shortExpired, title="PDL Retest Short Expired", text="Expired", style=shape.xcross, location=location.belowbar, color=color.new(color.gray, 0), textcolor=color.gray, size=size.tiny)
