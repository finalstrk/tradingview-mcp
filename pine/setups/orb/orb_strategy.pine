//@version=6
strategy("DT ORB v1", overlay=true, initial_capital=1000000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=10,
     commission_type=strategy.commission.percent, commission_value=0.005,
     slippage=2, process_orders_on_close=true, calc_on_every_tick=false)

// Inputs
sessionPreset = input.string("RTH", "Session preset", options=["Tokyo", "London", "NY", "RTH", "Custom"], group="Session")
customSession = input.session("0930-1600", "Custom session", group="Session")
customTimezone = input.string("America/New_York", "Custom timezone", group="Session")
orWindow = input.session("0930-1000", "OR window", group="Session")
maxOrWidthAtr = input.float(2.5, "Max OR width (ATR mult)", minval=0.1, step=0.1, group="Filters")
signalValidityBars = input.int(24, "Signal validity (bars)", minval=1, group="Filters")

// Session preset resolution
sessStr = switch sessionPreset
    "Tokyo" => "0900-1500"
    "London" => "0800-1630"
    "NY" => "0930-1600"
    "RTH" => "0930-1600"
    => customSession

tzStr = switch sessionPreset
    "Tokyo" => "Asia/Tokyo"
    "London" => "Europe/London"
    "NY" => "America/New_York"
    "RTH" => "America/New_York"
    => customTimezone

inSession = not na(time(timeframe.period, sessStr, tzStr))
inOrWindow = not na(time(timeframe.period, orWindow, tzStr))
isNewDay = timeframe.change("D")

// Opening range state
var float orHigh = na
var float orLow = na
var bool orLocked = false
var int orLockBar = na
var bool tradedToday = false
var float activeStop = na
var float activeTp1 = na
var float activeTp2 = na

if isNewDay
    orHigh := na
    orLow := na
    orLocked := false
    orLockBar := na
    tradedToday := false

if inOrWindow
    orHigh := na(orHigh) ? high : math.max(orHigh, high)
    orLow := na(orLow) ? low : math.min(orLow, low)
    orLocked := false
    orLockBar := na

if inOrWindow[1] and not inOrWindow and not na(orHigh) and not na(orLow)
    orLocked := true
    orLockBar := bar_index

// Signal filters and triggers
atrValue = ta.atr(14)
longCross = ta.crossover(close, orHigh)
shortCross = ta.crossunder(close, orLow)
hasRange = not na(orHigh) and not na(orLow) and orHigh > orLow
orWidth = hasRange ? orHigh - orLow : na
barsSinceLock = orLocked and not na(orLockBar) ? bar_index - orLockBar : na
widthOk = orLocked and hasRange and orWidth < atrValue * maxOrWidthAtr
validityOk = orLocked and not na(barsSinceLock) and barsSinceLock <= signalValidityBars
longSignal = inSession and widthOk and validityOk and not tradedToday and longCross
shortSignal = inSession and widthOk and validityOk and not tradedToday and shortCross

// Entries and exits
if longSignal
    activeStop := orLow
    activeTp1 := close + orWidth
    activeTp2 := close + orWidth * 2.0
    strategy.entry("Long", strategy.long)
    tradedToday := true

if shortSignal
    activeStop := orHigh
    activeTp1 := close - orWidth
    activeTp2 := close - orWidth * 2.0
    strategy.entry("Short", strategy.short)
    tradedToday := true

if strategy.position_size > 0 and not na(activeStop) and not na(activeTp1) and not na(activeTp2)
    strategy.exit("L-TP1", "Long", qty_percent=50, stop=activeStop, limit=activeTp1)
    strategy.exit("L-TP2", "Long", qty_percent=50, stop=activeStop, limit=activeTp2)

if strategy.position_size < 0 and not na(activeStop) and not na(activeTp1) and not na(activeTp2)
    strategy.exit("S-TP1", "Short", qty_percent=50, stop=activeStop, limit=activeTp1)
    strategy.exit("S-TP2", "Short", qty_percent=50, stop=activeStop, limit=activeTp2)

if inSession[1] and not inSession
    strategy.close_all("EOD")
    activeStop := na
    activeTp1 := na
    activeTp2 := na

// Visual history and levels
orHighPlot = plot(inOrWindow or orLocked ? orHigh : na, "OR High", color=color.new(color.green, 0), linewidth=2, style=plot.style_linebr)
orLowPlot = plot(inOrWindow or orLocked ? orLow : na, "OR Low", color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)
fill(orHighPlot, orLowPlot, color=color.new(color.yellow, 90), title="OR Range")
plotshape(longSignal, title="ORB Long", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), text="ORB L", size=size.tiny)
plotshape(shortSignal, title="ORB Short", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), text="ORB S", size=size.tiny)
